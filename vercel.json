{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.php",
      "use": "@vercel/php"
    }
  ],
  "rewrites": [
    {
      "src": "/backend/index.php",
      "dest": "/backend/index.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/frontend/dashboard/$1"
    },
    {
      "src": "/quiz/(.*)",
      "dest": "/frontend/quiz/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ]
}
{
  "version": 2,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/assets/$1"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/frontend/dashboard/$1"
    },
    {
      "source": "/quiz/(.*)",
      "destination": "/frontend/quiz/$1"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}